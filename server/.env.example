# Server
NODE_ENV=development
PORT=3001

# First admin (npm run seed:admin) — optional overrides
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_PASSWORD=YourSecurePassword123!
# ADMIN_FIRST_NAME=Admin
# ADMIN_LAST_NAME=User

# MongoDB (local Compass default)
MONGODB_URI=mongodb://127.0.0.1:27017/web-crm

# CORS — URL фронтенда (Vite dev server)
CLIENT_URL=http://localhost:5173

# JWT (сгенерируйте свои секреты, минимум 32 символа)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (required for employee invites)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SaleCRM <your-email@gmail.com>
